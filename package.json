{
	"name": "n8n-nodes-viber-bot",
	"version": "1.1.6",
	"description": "n8n community node for Viber Bot API (https://github.com/andrey0001/n8n-nodes-viber-bot)",
	"license": "MIT",
	"keywords": [
		"n8n-community-node-package",
    "n8n-nodes-viber-bot",
    "viber-bot",
    "viberbot",
    "viber",
    "bot",
    "n8n",
    "n8n-viber",
    "n8n-viber-bot"
	],
  "homepage": "https://github.com/andrey0001/n8n-nodes-viber-bot",
  "author": {
    "name": "Andrey Sorokin (aka shadow_alone)",
    "email": "andrey.s@viber.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/andrey0001/n8n-nodes-viber-bot.git"
  },
	"main": "dist/index.js",

  "scripts": {
    "build": "tsc && npm run copy:icons",
    "copy:icons": "copyfiles -u 1 \"src/nodes/**/*.svg\" dist",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "lintfix": "eslint src --ext .ts --fix",
    "prepublishOnly": "npm run build"
  },
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/ViberBotApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/ViberBot/ViberBot.node.js",
			"dist/nodes/ViberBot/ViberBotTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/jest": "^30.0.0",
		"eslint": "^9.29.0",
		"jest": "^30.4.2",
		"prettier": "^3.2.5",
		"ts-jest": "^29.4.11",
		"typescript": "^5.3.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
